# Copia a .env y rellena.  cp .env.example .env
# El servidor NO arranca si SECURECHAT_JWT_SECRET está vacío o es el placeholder.

# OBLIGATORIO — genera uno con:  openssl rand -hex 32
SECURECHAT_JWT_SECRET=

# Modo de registro: private (invitación) | public | mesh_private | mesh_public
SECURECHAT_MODE=private

# Puerto publicado en el host
SECURECHAT_PORT=8443

# TLS: por defecto desactivado (usa un proxy inverso para HTTPS). Para TLS nativo,
# pon SECURECHAT_TLS=true y monta cert/key en /data, apuntando con:
#   SECURECHAT_TLS_CERT=/data/cert.pem
#   SECURECHAT_TLS_KEY=/data/key.pem
# SECURECHAT_TLS=false

# Carpeta del host donde se guarda data.db (y config.toml opcional)
DATA_DIR=./data

# Zona horaria del contenedor
TZ=Europe/Madrid
